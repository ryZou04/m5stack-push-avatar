// config.h.example
//
// Copy this file to src/config.h and fill in your real WiFi credentials and
// bridge server URLs. src/config.h is gitignored so your creds stay local.

#ifndef CONFIG_H
#define CONFIG_H

// ── Network (connect-priority order) ─────────────────────────────
#define WIFI_NETWORK_COUNT 2

// 0: home WiFi -> PC bridge
#define WIFI_SSID_0       "your-home-ssid"
#define WIFI_PASSWORD_0   "your-home-password"
#define SERVER_URL_0      "http://192.168.1.10:5050"   // your PC's LAN IP

// 1: phone hotspot fallback (optional — set WIFI_NETWORK_COUNT to 1 to skip)
#define WIFI_SSID_1       "YunoHotspot"
#define WIFI_PASSWORD_1   "your_hotspot_pass"
#define SERVER_URL_1      "http://172.20.10.1:5050"

// ── Display / Speaker ───────────────────────────────────────────
#define DISPLAY_BRIGHTNESS 70
#define SPEAKER_VOLUME     200

// ── Microphone (working defaults; see project CLAUDE.md for tuning) ──
#define MIC_SAMPLE_RATE             16000
#define MIC_MAX_RECORD_SECONDS      8
#define MIC_TRIGGER_RMS             0.0095f
#define MIC_TRIGGER_HOLD_MS         280
#define MIC_SILENCE_RMS             0.0020f
#define MIC_SILENCE_HOLD_MS         1500
#define MIC_FRAME_SAMPLES           1600        // >=1600 to avoid DMA stutter
#define MIC_MIN_VALID_SAMPLES       5200
#define MIC_VOICE_CONFIRM_RMS       0.004f
#define PRE_TRIGGER_BUFFER_SAMPLES  12800       // prevents head-of-speech clipping
#define MIC_MAGNIFICATION           2
#define MIC_NOISE_FILTER_LEVEL      0           // 0=off, raise if noisy

// ── HTTP timeouts (ms) ──────────────────────────────────────────
#define HTTP_TIMEOUT_STT      30000
#define HTTP_TIMEOUT_CHAT     30000
#define HTTP_TIMEOUT_DOWNLOAD 10000
#define HTTP_TIMEOUT_SHORT     5000

// ── Background polling intervals (ms) ───────────────────────────
#define SERVER_HOUR_SYNC_INTERVAL   300000      // 5 min
#define NOTIFICATION_CHECK_INTERVAL  60000      // 1 min

#endif // CONFIG_H
